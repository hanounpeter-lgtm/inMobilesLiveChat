# Production web image — builds the Vite SPA and serves it via Caddy, which
# also reverse-proxies /api and /socket.io to the API container.
FROM node:22-bookworm-slim AS build

WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
COPY . .
RUN pnpm install --frozen-lockfile
# Bundle the animated sticker pack (gitignored; fetched at build time).
RUN node scripts/download-stickers.cjs || true
RUN pnpm --filter @inmobiles/shared-types build \
  && pnpm --filter @inmobiles/web build

FROM caddy:2-alpine
COPY --from=build /app/apps/web/dist /srv
COPY infra/prod/Caddyfile /etc/caddy/Caddyfile
EXPOSE 8055

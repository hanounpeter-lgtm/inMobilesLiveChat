# Copy to .env.prod on the server and fill in the CHANGE_ME values.
# Everything here is read by docker-compose.prod.yml and the API container.

# ---- Public address (bare-IP HTTPS deploy; self-signed cert on 8055) ----
PUBLIC_IP=16.170.99.233
WEB_ORIGIN=https://16.170.99.233:8055
NODE_ENV=production
# True because we serve HTTPS (self-signed). Required for calls (secure context).
COOKIE_SECURE=true
API_PORT=3001

# ---- Postgres ----
POSTGRES_USER=inchat
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=inchat
DATABASE_URL=postgresql://inchat:CHANGE_ME_db_password@postgres:5432/inchat

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- Auth ----
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_long_random_secret
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- Object storage (MinIO) ----
# S3_ENDPOINT = internal (server→MinIO over the Docker network)
# S3_PUBLIC_ENDPOINT = what the browser uses for presigned file URLs
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://16.170.99.233:9000
S3_ACCESS_KEY=inchat
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=chat-files

# ---- Calls (LiveKit; signaling proxied through :8055/rtc, media on :8057) ----
LIVEKIT_URL=wss://16.170.99.233:8055
# Internal address the API uses for LiveKit's HTTP API (screen-share grants).
LIVEKIT_INTERNAL_URL=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ---- Mail (invite emails; optional) ----
SMTP_HOST=mailpit
SMTP_PORT=1025

# ---- Policy ----
ALLOW_PUBLIC_SIGNUP=true
ALLOWED_EMAIL_DOMAIN=inmobiles.com

# ---- GIF search (optional; paste your GIPHY key) ----
GIPHY_API_KEY=
TENOR_API_KEY=

{
  "name": "@inmobiles/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "predev": "node scripts/free-port.cjs 3001",
    "dev": "nest start --watch",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "user:create": "ts-node --transpile-only scripts/create-user.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "@inmobiles/shared-types": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/client": "^6.2.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.2",
    "livekit-server-sdk": "^2.17.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.7",
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}

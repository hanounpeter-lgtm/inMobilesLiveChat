generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  owner
  admin
  member
  guest
}

enum ChannelType {
  public
  private
  dm
  group_dm
}

enum NotifyLevel {
  all
  mentions
  none
}

enum NotificationType {
  mention
  dm
  thread_reply
  channel_invite
}

enum AttachmentStatus {
  pending
  ready
}

enum CallType {
  audio
  video
}

enum PostingPolicy {
  everyone
  admins_only
}

enum ClockKind {
  clock_in
  break_start
  break_end
  clock_out
}

model User {
  id           String    @id @default(uuid(7)) @db.Uuid
  email        String    @unique
  passwordHash String?   @map("password_hash")
  displayName  String    @map("display_name")
  avatarUrl    String?   @map("avatar_url")
  statusText   String?   @map("status_text")
  statusEmoji  String?   @map("status_emoji")
  department   String?
  jobTitle     String?   @map("job_title")
  timezone     String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  workspaceMemberships WorkspaceMember[]
  channelMemberships   ChannelMember[]
  messages             Message[]
  reactions            Reaction[]
  refreshTokens        RefreshToken[]
  notifications        Notification[]    @relation("NotificationRecipient")
  actedNotifications   Notification[]    @relation("NotificationActor")
  attachments          Attachment[]
  pushSubscriptions    PushSubscription[]
  startedCalls         Call[]
  channelInvites       ChannelInvite[]
  workspaceInvites     WorkspaceInvite[]
  clockEvents          WorkClockEvent[]
  savedMessages        SavedMessage[]
  scheduledMeetings    ScheduledMeeting[]
  invitationsSent      ChannelInvitation[] @relation("InvitationsSent")
  invitationsReceived  ChannelInvitation[] @relation("InvitationsReceived")

  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid(7)) @db.Uuid
  name      String
  slug      String   @unique
  iconUrl   String?  @map("icon_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  members  WorkspaceMember[]
  channels Channel[]
  invites  WorkspaceInvite[]

  @@map("workspaces")
}

model WorkspaceInvite {
  id          String        @id @default(uuid(7)) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  email       String
  role        WorkspaceRole @default(member)
  token       String        @unique
  invitedById String        @map("invited_by") @db.Uuid
  expiresAt   DateTime      @map("expires_at") @db.Timestamptz()
  acceptedAt  DateTime?     @map("accepted_at") @db.Timestamptz()
  revokedAt   DateTime?     @map("revoked_at") @db.Timestamptz()
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId, email])
  @@map("workspace_invites")
}

model WorkspaceMember {
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(member)
  joinedAt    DateTime      @default(now()) @map("joined_at") @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Channel {
  id            String      @id @default(uuid(7)) @db.Uuid
  workspaceId   String      @map("workspace_id") @db.Uuid
  type          ChannelType
  name          String?
  topic         String?
  description   String?
  createdById   String?     @map("created_by") @db.Uuid
  dmKey         String?     @unique @map("dm_key")
  isArchived    Boolean     @default(false) @map("is_archived")
  isDefault     Boolean     @default(false) @map("is_default")
  postingPolicy PostingPolicy @default(everyone) @map("posting_policy")
  lastMessageAt DateTime?   @map("last_message_at") @db.Timestamptz()
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   ChannelMember[]
  messages  Message[]
  calls     Call[]
  invites   ChannelInvite[]
  meetings  ScheduledMeeting[]
  invitations ChannelInvitation[]

  @@unique([workspaceId, name])
  @@index([workspaceId, type])
  @@map("channels")
}

model ChannelInvitation {
  id        String   @id @default(uuid(7)) @db.Uuid
  channelId String   @map("channel_id") @db.Uuid
  inviterId String   @map("inviter_id") @db.Uuid
  inviteeId String   @map("invitee_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  inviter User    @relation("InvitationsSent", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User    @relation("InvitationsReceived", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([channelId, inviteeId])
  @@index([inviteeId, createdAt(sort: Desc)])
  @@map("channel_invitations")
}

model SavedMessage {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("saved_messages")
}

model ScheduledMeeting {
  id          String   @id @default(uuid(7)) @db.Uuid
  channelId   String   @map("channel_id") @db.Uuid
  createdById String   @map("created_by_id") @db.Uuid
  title       String
  description String?
  type        CallType @default(video)
  scheduledAt DateTime @map("scheduled_at") @db.Timestamptz()
  reminded    Boolean  @default(false)
  joinCode    String?  @unique @map("join_code")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([channelId, scheduledAt])
  @@index([scheduledAt, reminded])
  @@map("scheduled_meetings")
}

// ---------- Collaboration (polls, tasks, notes, templates, calendar) ----------
model Poll {
  id          String   @id @default(uuid(7)) @db.Uuid
  messageId   String   @unique @map("message_id") @db.Uuid
  channelId   String   @map("channel_id") @db.Uuid
  question    String
  multiple    Boolean  @default(false)
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  options PollOption[]

  @@map("polls")
}

model PollOption {
  id     String @id @default(uuid(7)) @db.Uuid
  pollId String @map("poll_id") @db.Uuid
  text   String

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  optionId  String   @map("option_id") @db.Uuid
  pollId    String   @map("poll_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([optionId, userId])
  @@index([pollId])
  @@map("poll_votes")
}

model Task {
  id          String    @id @default(uuid(7)) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  channelId   String?   @map("channel_id") @db.Uuid
  creatorId   String    @map("creator_id") @db.Uuid
  assigneeId  String?   @map("assignee_id") @db.Uuid
  title       String
  done        Boolean   @default(false)
  dueAt       DateTime? @map("due_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([channelId])
  @@index([assigneeId, done])
  @@index([creatorId, done])
  @@map("tasks")
}

model ChannelNote {
  channelId   String   @id @map("channel_id") @db.Uuid
  content     String   @default("")
  updatedById String?  @map("updated_by_id") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("channel_notes")
}

model MessageTemplate {
  id          String   @id @default(uuid(7)) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  title       String
  body        String
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([workspaceId])
  @@map("message_templates")
}

model CalendarEvent {
  id          String    @id @default(uuid(7)) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  title       String
  description String?
  startAt     DateTime  @map("start_at") @db.Timestamptz()
  endAt       DateTime? @map("end_at") @db.Timestamptz()
  channelId   String?   @map("channel_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  attendees EventAttendee[]

  @@index([workspaceId, startAt])
  @@map("calendar_events")
}

model EventAttendee {
  eventId String @map("event_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid
  status  String @default("pending")

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId])
  @@map("event_attendees")
}

model ChannelMember {
  channelId         String      @map("channel_id") @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  lastReadMessageId String?     @map("last_read_message_id") @db.Uuid
  lastReadAt        DateTime?   @map("last_read_at") @db.Timestamptz()
  notifyLevel       NotifyLevel @default(all) @map("notify_level")
  isStarred         Boolean     @default(false) @map("is_starred")
  joinedAt          DateTime    @default(now()) @map("joined_at") @db.Timestamptz()

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
  @@map("channel_members")
}

model Message {
  id              String    @id @default(uuid(7)) @db.Uuid
  channelId       String    @map("channel_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  parentMessageId String?   @map("parent_message_id") @db.Uuid
  content         String
  clientMsgId     String    @map("client_msg_id") @db.Uuid
  replyCount      Int       @default(0) @map("reply_count")
  lastReplyAt     DateTime? @map("last_reply_at") @db.Timestamptz()
  isEdited        Boolean   @default(false) @map("is_edited")
  isPinned        Boolean   @default(false) @map("is_pinned")
  forwardedFromId String?   @map("forwarded_from_id") @db.Uuid
  contentTsv      Unsupported("tsvector")? @map("content_tsv")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  channel       Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author        User         @relation(fields: [userId], references: [id])
  parentMessage Message?     @relation("Thread", fields: [parentMessageId], references: [id])
  replies       Message[]    @relation("Thread")
  forwardedFrom Message?     @relation("MessageForward", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards      Message[]    @relation("MessageForward")
  reactions     Reaction[]
  attachments   Attachment[]
  savedBy       SavedMessage[]

  @@unique([channelId, clientMsgId])
  @@index([channelId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([parentMessageId, createdAt])
  @@index([contentTsv], type: Gin)
  @@map("messages")
}

model Reaction {
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@map("reactions")
}

model Attachment {
  id          String           @id @default(uuid(7)) @db.Uuid
  messageId   String?          @map("message_id") @db.Uuid
  channelId   String?          @map("channel_id") @db.Uuid
  uploaderId  String           @map("uploader_id") @db.Uuid
  workspaceId String           @map("workspace_id") @db.Uuid
  s3Key       String           @map("s3_key")
  filename    String
  mimeType    String           @map("mime_type")
  sizeBytes   BigInt           @map("size_bytes")
  width       Int?
  height      Int?
  thumbS3Key  String?          @map("thumb_s3_key")
  status      AttachmentStatus @default(pending)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  message  Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  uploader User     @relation(fields: [uploaderId], references: [id])

  @@index([messageId])
  @@map("attachments")
}

model Notification {
  id          String           @id @default(uuid(7)) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  workspaceId String           @map("workspace_id") @db.Uuid
  type        NotificationType
  messageId   String?          @map("message_id") @db.Uuid
  channelId   String?          @map("channel_id") @db.Uuid
  actorId     String?          @map("actor_id") @db.Uuid
  readAt      DateTime?        @map("read_at") @db.Timestamptz()
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt, channelId])
  @@map("notifications")
}

model RefreshToken {
  id         String    @id @default(uuid(7)) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  familyId   String    @map("family_id") @db.Uuid
  deviceInfo String?   @map("device_info")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Call {
  id          String    @id @default(uuid(7)) @db.Uuid
  channelId   String    @map("channel_id") @db.Uuid
  startedById String    @map("started_by") @db.Uuid
  livekitRoom String    @unique @map("livekit_room")
  type        CallType
  isRecording Boolean   @default(false) @map("is_recording")
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  endedAt     DateTime? @map("ended_at") @db.Timestamptz()

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  startedBy User    @relation(fields: [startedById], references: [id])

  @@index([channelId, endedAt])
  @@map("calls")
}

model WorkClockEvent {
  id          String    @id @default(uuid(7)) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  kind        ClockKind
  at          DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, at(sort: Desc)])
  @@map("work_clock_events")
}

model ChannelInvite {
  id          String    @id @default(uuid(7)) @db.Uuid
  channelId   String    @map("channel_id") @db.Uuid
  token       String    @unique
  createdById String    @map("created_by") @db.Uuid
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@map("channel_invites")
}

model PushSubscription {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  keys      Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

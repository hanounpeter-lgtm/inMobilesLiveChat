# Copy to .env at the repo root. apps/api loads this via @nestjs/config.
DATABASE_URL=postgresql://inmobiles:inmobiles@localhost:5432/inmobiles_chat
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

API_PORT=3001
WEB_ORIGIN=http://localhost:5173

# Set to false to disable the public "Create account" page (invite-only mode)
ALLOW_PUBLIC_SIGNUP=true

# Only emails on this domain may register or be invited (empty = any domain)
ALLOWED_EMAIL_DOMAIN=inmobiles.com

# S3 / MinIO (Phase 2 file uploads; compose provides these in dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=inmobiles
S3_SECRET_KEY=inmobiles-secret
S3_BUCKET=chat-files

# LiveKit (dev-mode credentials from `livekit-server --dev`)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# GIF search — free key at https://developers.giphy.com (Create Account →
# Create an App → API). Tenor also supported but is closed to new projects.
GIPHY_API_KEY=
TENOR_API_KEY=

# Mail (Mailpit in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
